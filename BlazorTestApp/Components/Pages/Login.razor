@page "/"
@using System.Security.Cryptography
@using System.Text
@using Microsoft.AspNetCore.Identity
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager


<PageTitle>Login</PageTitle>

<div class="container-fluid gap-3 flex-wrap">
    <div class="row align-items-center">
        <div class="col mh-100 d-inline-block align-items-start">
            <div class="col">
                <img src="assets/castle_grey.png" width="102" alt="Cool Image">
            </div>
            <div class="row">
                <h6 class="text-start text-body-secondary">Start your journey</h6>
                <h5 class="text-start">Sigh In to The App</h5>
                <div class="input-group" style="margin-top: 6px">
                    <input 
                        type="text" 
                        class="form-control" 
                        placeholder="E-Mail" 
                        aria-label="Username" 
                        aria-describedby="basic-addon1"
                        @bind="email"
                        required>
                    <span class="input-group-text bi bi-envelope-at-fill"></span>
                </div>
                <div class="input-group" style="margin-top: 6px">
                    <input 
                        type="password" 
                        class="form-control" 
                        placeholder="Password" 
                        aria-label="Username" 
                        aria-describedby="basic-addon1"
                        @bind="password">
                    <span class="input-group-text bi bi-key-fill"></span>
                </div>
                <div class="form-check" style="margin-top: 6px">
                    <input class="form-check-input" type="checkbox" value="" id="checkChecked" style="margin-left: -12px">
                    <label class="form-check-label" for="checkChecked" style="margin-left: 6px">Remember me</label>
                </div>
                <div class="d-grid" style="margin-top: 6px">
                    <button type="button" class="btn btn-primary align-content-lg-stretch" @onclick="SighIn">Sigh in</button>
                </div>
            </div>
            <div class="row align-bottom" style="margin-top: 6px">
                <div class="col">
                    <p class="text-start">Don't have an account? <a href="#" class="link-offset-1">Sing up</a></p></div>
                <div class="col">
                    <p class="text-end"><a href="#" class="link-offset-1">Forgot password?</a></p></div>
            </div>
        </div>
        <div class="col d-none d-lg-block">
            <img src="assets/uncolored_castle.png" class="card-img-top rounded" alt="Cool Image">
        </div>
    </div>
</div>

@code {

    string email = "";
    string password = "";
    
    const string correctEmail = "admin";
    const string correctPassword = "fb001dfcffd1c899f3297871406242f097aecf1a5342ccf3ebcd116146188e4b"; // admin
    
    private void SighIn()
    {
        Console.WriteLine(email + " " + password);
        if (CheckLogin())
        {
            Navigation.NavigateTo("UserPage");
        }
        
    }

    private bool CheckLogin()
    {
        return true;
        if (email == correctEmail && GenerateHash(password) == correctPassword)
        {
            return true;
        }
        return false;
        
    }
    
    private static string GenerateHash(string text)
    {
        byte[] bytesData = Encoding.UTF8.GetBytes(text);
        SHA3_256 sha = SHA3_256.Create();
        byte[] hashBytes = sha.ComputeHash(bytesData);
        string hashString = BitConverter.ToString(hashBytes).Replace("-", "");
        return hashString.ToLower();
    }

}